# ============================
# Hardhat / Deployment
# ============================
# DO NOT COMMIT REAL VALUES
# Copy this file to `.env` and fill in your own secrets.

# Private key of the deployer wallet (no quotes, 0x-prefixed)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polygon mainnet RPC URL (Infura, Alchemy, etc.)
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID

# Ethereum mainnet RPC URL
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Address that will be the initial owner of the contract
CONTRACT_OWNER_ADDRESS=0xYourEOAHere

# ============================
# Frontend (shared via process.env)
# ============================

# After deployment, set this to the deployed contract address
NEXT_PUBLIC_CONTRACT_ADDRESS=0xDeployedContractAddressHere

# Chain ID: Polygon mainnet (137) or Ethereum mainnet (1)
NEXT_PUBLIC_CHAIN_ID=137

# ============================
# Hardhat / Deployment
# ============================
# DO NOT COMMIT REAL VALUES

PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_PROJECT_ID
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

CONTRACT_OWNER_ADDRESS=0xYourEOAHere

# Fee recipient and mint fee (in wei)
FEE_RECIPIENT_ADDRESS=0xYourFeeRecipient
MINT_FEE_WEI=0

# ============================
# Frontend shared
# ============================

# Default chain ID (137 = Polygon, 1 = Ethereum)
NEXT_PUBLIC_CHAIN_ID=137

# Deployed contract addresses per chain
NEXT_PUBLIC_POLYGON_CONTRACT=0xPolygonContractAddressHere
NEXT_PUBLIC_ETHEREUM_CONTRACT=0xEthereumContractAddressHere

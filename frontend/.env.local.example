# Frontend-visible
NEXT_PUBLIC_CONTRACT_ADDRESS=0xDeployedContractAddressHere
# 137 for Polygon mainnet, 1 for Ethereum mainnet
NEXT_PUBLIC_CHAIN_ID=137

# Backend-only (Next.js API routes)
# DO NOT COMMIT REAL VALUES

# OpenAI Images–style endpoint and key
AI_IMAGE_ENDPOINT=https://api.openai.com/v1/images/generations
AI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# NFT.Storage API key
NFT_STORAGE_API_KEY=YOUR_NFT_STORAGE_API_KEY_HERE

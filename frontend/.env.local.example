# Default chain ID (137 = Polygon, 1 = Ethereum)
NEXT_PUBLIC_CHAIN_ID=137

# Deployed contract addresses per chain
NEXT_PUBLIC_POLYGON_CONTRACT=0xPolygonContractAddressHere
NEXT_PUBLIC_ETHEREUM_CONTRACT=0xEthereumContractAddressHere

# Backend-only (Next.js API routes)
AI_IMAGE_ENDPOINT=https://api.openai.com/v1/images/generations
AI_API_KEY=YOUR_OPENAI_API_KEY_HERE
NFT_STORAGE_API_KEY=YOUR_NFT_STORAGE_API_KEY_HERE

# Simple shared secret for API access
AFTERGLOW_API_KEY=CHANGE_ME_TO_A_STRONG_SECRET
